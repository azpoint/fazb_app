{
	"name": "fazb_app",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "env-cmd -f .env.local next dev",
		"migrate": "env-cmd -f .env.local npx knex migrate:latest --knexfile db/knexfile.js --debug",
		"rollback": "env-cmd -f .env.local npx knex migrate:rollback --knexfile db/knexfile.js",
		"rollback-all": "env-cmd -f .env.local npx knex migrate:rollback --all --knexfile db/knexfile.js",
		"seed": "env-cmd -f .env.local npx knex seed:run --knexfile db/knexfile.js --debug",
		"build": "next build",
		"start": "next start",
		"lint": "next lint"
	},
	"dependencies": {
		"@mdxeditor/editor": "^3.31.0",
		"env-cmd": "^10.1.0",
		"fs-extra": "^11.3.0",
		"knex": "^3.1.0",
		"next": "15.3.1",
		"pg": "^8.15.6",
		"postcss": "^8.5.3",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-icons": "^5.5.0",
		"slugify": "^1.6.6",
		"uuid": "^11.1.0",
		"zod": "^3.24.3"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4.1.4",
		"prettier": "^3.5.3",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"tailwindcss": "^4.1.4"
	}
}
